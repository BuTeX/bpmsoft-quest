PORT=4173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bpmsoft_quest
PGSSLMODE=disable
# Для production используйте PGSSLMODE=verify-full и путь к корневому сертификату.
PGSSLROOTCERT=
PGSSLREJECTUNAUTHORIZED=true
REQUIRE_DATABASE=true
ADMIN_PASSWORD=replace-with-a-long-random-password
APP_BASE_URL=http://localhost:4173
TRUST_PROXY=false
REQUIRE_EMAIL_VERIFICATION=false
REQUIRE_EMAIL_DELIVERY=false
MAIL_WEBHOOK_URL=
MAIL_WEBHOOK_TOKEN=
METRICS_TOKEN=replace-with-a-long-random-token
LOG_FORMAT=json
LEGAL_ENTITY_NAME=
PRIVACY_CONTACT_EMAIL=
LEGAL_JURISDICTION=
POLICY_VERSION=2026-07-23
